"meta": {
"entryNodeId": "N_TrainStory_001",
"schemaVersion": 1,
"storyId": "train_story"
},
"nodes": [{
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "（弯腰捡起，目光落在那行字上）你的笔？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_001",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "是的，谢谢",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_002",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "我可以坐这吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_003",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "可以，这没人坐",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_004",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "多谢",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_005",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "客气",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_006",
"nodeType": "Dialogue"
}, {
"eventType": "object.set_state",
"nodeId": "N_TrainStory_007",
"nodeType": "EmitEvent",
"params": {
"enabled": true,
"object": "train.girl",
"visible": true
}
}, {
"eventType": "object.set_state",
"nodeId": "N_TrainStory_008",
"nodeType": "EmitEvent",
"params": {
"enabled": false,
"object": "train.girl_luggage",
"visible": true
}
}, {
"eventType": "dialogue.change_posture",
"nodeId": "N_TrainStory_009",
"nodeType": "EmitEvent",
"params": {
"posture": "girl_sit_front",
"role": "girl"
}
}, {
"eventType": "dialogue.change_face",
"nodeId": "N_TrainStory_010",
"nodeType": "EmitEvent",
"params": {
"face": "expression_girl_expressionless",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "……",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_011",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "……",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_012",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.change_face",
"nodeId": "N_TrainStory_013",
"nodeType": "EmitEvent",
"params": {
"face": "expression_girl_smile_1123",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "你写的……你在等海？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_014",
"nodeType": "Dialogue"
}, {
"eventType": "journal.unlock_entry",
"nodeId": "N_TrainStory_015",
"nodeType": "EmitEvent",
"params": {
"entry_id": "sea_end_note",
"source": "bedroom_notebook",
"text": "想要去看海的尽头"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "不知道，只是在想",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_016",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "……",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_017",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "……",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_018",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.change_face",
"nodeId": "N_TrainStory_019",
"nodeType": "EmitEvent",
"params": {
"face": "expression_girl_expressionless",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "这趟车的人还挺少的",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_020",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "你刚上来？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_021",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "嗯",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_022",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "三站前车上还是挤满了人，我站在车厢连接处挤了有两个小时",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_023",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "看来我还是挺幸运的",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_024",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "幸好那里风大，还能闻到铁轨的味道。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_025",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "铁轨有什么味道？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_026",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "锈，还有一种干干的热，像夏天柏油马路被晒了很久之后的味道，你闻过吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_027",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "（摇摇头）",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_028",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "那好吧。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_029",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "你......去哪儿？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_030",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "不知道",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_031",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "橘子，尝尝看",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_033",
"nodeType": "Dialogue"
}, {
"multiDialogue": {
"lines": [{
"textKey": "谢谢。"
}, {
"textKey": "不知道？"
}],
"speakerId": "我"
},
"nodeId": "N_TrainStory_034",
"nodeType": "MultiDialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "就是——不知道要在哪里停下来。我买了张往南走的票，想在哪一站觉得“到了”，就在哪一站下",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_035",
"nodeType": "Dialogue"
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_036",
"nodeType": "EmitEvent",
"params": {
"environment": "train.LeftWindowViewVisual",
"state": "field_left"
}
}, {
"eventType": "dialogue.change_posture",
"nodeId": "N_TrainStory_037",
"nodeType": "EmitEvent",
"params": {
"posture": "girl_look_window",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "……",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_038",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "那你呢？你是要去什么地方，还是要离开什么地方？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_039",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "我要去上学……或者不去，我还没想好",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_040",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "所以你是带着一个“未决定”去旅行",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_041",
"nodeType": "Dialogue"
}, {
"multiDialogue": {
"lines": [{
"textKey": "……"
}, {
"textKey": "不是旅行，是去报到。但我到现在也没决定要不要在那下车"
}],
"speakerId": "我"
},
"nodeId": "N_TrainStory_042",
"nodeType": "MultiDialogue"
}, {
"eventType": "dialogue.change_posture",
"nodeId": "N_TrainStory_043",
"nodeType": "EmitEvent",
"params": {
"posture": "girl_sit_front",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "那个方向是你自己觉得好的吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_044",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "家里人觉得是",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_045",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "那你觉得呢？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_046",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "我也没想好",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_047",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "其实不用想太多。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_048",
"nodeType": "Dialogue"
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_049",
"nodeType": "EmitEvent",
"params": {
"environment": "train.BookVisual",
"state": "book"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "你看过吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_050",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "很久以前看过，只依稀记得结尾",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_051",
"nodeType": "Dialogue"
}, {
"eventType": "journal.unlock_entry",
"nodeId": "N_TrainStory_052",
"nodeType": "EmitEvent",
"params": {
"entry_id": "biancheng_ending_quote",
"source": "bedroom_notebook",
"text": "这个人也许永远不回来了，也许明天回来。"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "你还记得结尾那句话吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_053",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "（摇摇头）......太久了",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_054",
"nodeType": "Dialogue"
}, {
"eventType": "audio.play_sound",
"nodeId": "N_TrainStory_055",
"nodeType": "EmitEvent",
"params": {
"object": "train.window_view",
"sound": "train_pass_long_noise"
}
}, {
"eventType": "object.play_animation",
"nodeId": "N_TrainStory_056",
"nodeType": "EmitEvent",
"params": {
"animation": "train_pass_hair_wind",
"object": "train.window_view"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "“#@￥%…&（，*#——@#￥%……&#@！”",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_057",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.set_replay_line",
"nodeId": "N_TrainStory_058",
"nodeType": "EmitEvent",
"params": {
"line_id": "train_054",
"speaker": "girl",
"text": "这个人也许永远不回来了，也许明天回来。"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "%…&*（）#￥%&，*&……%￥#@！？#@…?",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_059",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.set_replay_line",
"nodeId": "N_TrainStory_060",
"nodeType": "EmitEvent",
"params": {
"line_id": "train_055",
"speaker": "girl",
"text": "那个结尾很好，你不觉得这很像所有的离别吗？"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "@#￥%……&*#@￥%…&*（）,#@…%…？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_061",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.set_replay_line",
"nodeId": "N_TrainStory_062",
"nodeType": "EmitEvent",
"params": {
"line_id": "train_056",
"speaker": "player",
"text": "你是说永远和明天，其实是一回事？"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "*&……%￥#@，！——@#￥,（）——#￥%&",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_063",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.set_replay_line",
"nodeId": "N_TrainStory_064",
"nodeType": "EmitEvent",
"params": {
"line_id": "train_057",
"speaker": "girl",
"text": "我是说，你不知道的事情，就不要急着定义。让它是也许就好了。"
}
}, {
"eventType": "audio.play_sound",
"nodeId": "N_TrainStory_065",
"nodeType": "EmitEvent",
"params": {
"object": "train.window_view",
"sound": "train_pass"
}
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_066",
"nodeType": "EmitEvent",
"params": {
"environment": "train.LeftWindowViewVisual",
"state": "sea_left"
}
}, {
"eventType": "dialogue.change_posture",
"nodeId": "N_TrainStory_067",
"nodeType": "EmitEvent",
"params": {
"posture": "girl_look_window",
"role": "girl"
}
}, {
"eventType": "timeline.wait",
"nodeId": "N_TrainStory_068",
"nodeType": "EmitEvent",
"params": {
"seconds": 5
}
}, {
"multiDialogue": {
"lines": [{
"textKey": "“各位旅客，请注意。列车即将驶入隧道，因车厢内供电异常导致照明失效，请您保持镇定，不要随意走动。"
}, {
"textKey": "请照顾好身边的老人和小孩，耐心等待。"
}],
"speakerId": "旁白"
},
"nodeId": "N_TrainStory_069",
"nodeType": "MultiDialogue"
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_070",
"nodeType": "EmitEvent",
"params": {
"environment": "train.lighting",
"state": "dark_tunnel"
}
}, {
"eventType": "timeline.wait",
"nodeId": "N_TrainStory_071",
"nodeType": "EmitEvent",
"params": {
"seconds": 5
}
}, {
"multiDialogue": {
"lines": [{
"textKey": "你有没有觉得，火车穿过隧道的时候，声音会变得更立体？"
}, {
"textKey": "你能听见车轮在铁轨接缝处的每一次撞击，就像是整列火车的呼吸声"
}],
"speakerId": "女孩"
},
"nodeId": "N_TrainStory_072",
"nodeType": "MultiDialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "火车的呼吸……我从来没这么想过",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_073",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "仔细听......",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_074",
"nodeType": "Dialogue"
}, {
"eventType": "timeline.wait",
"nodeId": "N_TrainStory_075",
"nodeType": "EmitEvent",
"params": {
"seconds": 15
}
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_076",
"nodeType": "EmitEvent",
"params": {
"environment": "train.lighting",
"state": "carriage_lit"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "感觉如何？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_077",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "刚才闭上眼睛听的时候，好像真的感觉到它在呼吸。不是比喻，是它真的在——吸气，停顿，吐气。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_078",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "所以......心情有更平复一些吗？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_079",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "……你怎么知道。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_080",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.change_face",
"nodeId": "N_TrainStory_081",
"nodeType": "EmitEvent",
"params": {
"face": "expression_girl_smile",
"role": "girl"
}
}, {
"eventType": "journal.unlock_entry",
"nodeId": "N_TrainStory_082",
"nodeType": "EmitEvent",
"params": {
"entry_id": "familiar_stranger_note",
"source": "bedroom_notebook",
"text": "我不知道这算不算夸奖。但她说这话的方式让我觉得，她认识我很久了，而不是一个小时。"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "因为我会读心术哦",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_083",
"nodeType": "Dialogue"
}, {
"multiDialogue": {
"lines": [{
"textKey": "她开始讲她的旅行，说自己从北方那座灰蒙蒙的城市出发，坐着慢火车一路向南。"
}, {
"textKey": "窗外原是光秃秃的原野，渐渐染上绿色，空气变得潮湿"
}, {
"textKey": "她说它见过工厂锈红的烟囱；见过平原上被风吹成波浪的麦田；见过长江上漂浮的薄雾；也见过小城石阶上的青苔"
}, {
"textKey": "最后，她垂下眼睛笑了笑，直勾勾看着我。"
}],
"speakerId": "旁白"
},
"nodeId": "N_TrainStory_084",
"nodeType": "MultiDialogue"
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "你很自由。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_085",
"nodeType": "Dialogue"
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "自由不只是想去哪儿就去哪儿，自由也是即便不知道自己要去哪儿，但也不害怕。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_086",
"nodeType": "Dialogue"
}, {
"eventType": "environment.set_state",
"nodeId": "N_TrainStory_087",
"nodeType": "EmitEvent",
"params": {
"environment": "train.window_view",
"state": "low_buildings"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "要不？留个联系方式？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_088",
"nodeType": "Dialogue"
}, {
"eventType": "object.play_animation",
"nodeId": "N_TrainStory_089",
"nodeType": "EmitEvent",
"params": {
"animation": "hand_over_on_table",
"object": "train.paper_note"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "可是我们之后大概率不会再见面了。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_090",
"nodeType": "Dialogue"
}, {
"eventType": "object.play_animation",
"nodeId": "N_TrainStory_091",
"nodeType": "EmitEvent",
"params": {
"animation": "disappear",
"object": "train.paper_note"
}
}, {
"eventType": "object.set_state",
"nodeId": "N_TrainStory_092",
"nodeType": "EmitEvent",
"params": {
"object": "train.paper_note",
"picked": true
}
}, {
"eventType": "object.set_state",
"nodeId": "N_TrainStory_093",
"nodeType": "EmitEvent",
"params": {
"object": "train.book_biancheng",
"picked": true
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "那没关系，我们以后还会相遇的。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_094",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.change_face",
"nodeId": "N_TrainStory_095",
"nodeType": "EmitEvent",
"params": {
"face": "expression_girl_smile",
"role": "girl"
}
}, {
"dialogue": {
"speakerId": "我",
"speechRate": 1,
"textKey": "你怎么能确定？",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_096",
"nodeType": "Dialogue"
}, {
"eventType": "dialogue.change_posture",
"nodeId": "N_TrainStory_097",
"nodeType": "EmitEvent",
"params": {
"posture": "girl_stand",
"role": "girl"
}
}, {
"eventType": "object.play_animation",
"nodeId": "N_TrainStory_098",
"nodeType": "EmitEvent",
"params": {
"animation": "disappear",
"object": "train.girl_luggage"
}
}, {
"eventType": "object.set_state",
"nodeId": "N_TrainStory_099",
"nodeType": "EmitEvent",
"params": {
"object": "train.girl_luggage",
"picked": true
}
}, {
"eventType": "journal.unlock_entry",
"nodeId": "N_TrainStory_100",
"nodeType": "EmitEvent",
"params": {
"entry_id": "orange_flower_slice",
"source": "bedroom_notebook",
"text": "一朵花形状的橘子干"
}
}, {
"dialogue": {
"speakerId": "女孩",
"speechRate": 1,
"textKey": "一路顺风。",
"voiceAsset": ""
},
"nodeId": "N_TrainStory_101",
"nodeType": "Dialogue"
}, {
